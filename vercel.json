{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "has": [{ "type": "host", "value": "staging-portal.garudahacks.com" }],
      "destination": "https://us-central1-garuda-hacks-development.cloudfunctions.net/api/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://us-central1-garuda-hacks-development.cloudfunctions.net/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}