{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "has": [
        {
          "type": "host",
          "value": "staging-portal.garudahacks.com"
        }
      ],
      "destination": "https://asia-southeast2-garuda-hacks-6-0.cloudfunctions.net/api/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://asia-southeast2-garuda-hacks-6-0.cloudfunctions.net/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}